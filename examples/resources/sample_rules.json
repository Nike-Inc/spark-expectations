{
  "product_id": "your_product",
  "dq_env": {
    "DEV": {
      "table_name": "dq_spark_dev.customer_order",
      "action_if_failed": "ignore",
      "enable_for_source_dq_validation": true,
      "enable_for_target_dq_validation": false,
      "is_active": true,
      "enable_error_drop_alert": false,
      "error_drop_threshold": 0,
      "priority": "medium"
    },
    "QA": {
      "table_name": "dq_spark_qa.customer_order",
      "action_if_failed": "ignore",
      "enable_for_source_dq_validation": true,
      "enable_for_target_dq_validation": false,
      "is_active": true,
      "enable_error_drop_alert": false,
      "error_drop_threshold": 0,
      "priority": "medium"
    },
    "PROD": {
      "table_name": "dq_spark_prod.customer_order",
      "action_if_failed": "ignore",
      "enable_for_source_dq_validation": true,
      "enable_for_target_dq_validation": false,
      "is_active": true,
      "enable_error_drop_alert": false,
      "error_drop_threshold": 0,
      "priority": "medium"
    }
  },
  "rules": [
    {
      "rule": "customer_id_not_null",
      "rule_type": "row_dq",
      "column_name": "customer_id",
      "expectation": "customer_id IS NOT NULL",
      "action_if_failed": "drop",
      "tag": "completeness",
      "description": "Customer ID must not be null",
      "priority": "high"
    },
    {
      "rule": "order_id_not_null",
      "rule_type": "row_dq",
      "column_name": "order_id",
      "expectation": "order_id IS NOT NULL",
      "action_if_failed": "drop",
      "tag": "completeness",
      "description": "Order ID must not be null",
      "priority": "high"
    },
    {
      "rule": "customer_name_not_null",
      "rule_type": "row_dq",
      "column_name": "customer_name",
      "expectation": "customer_name IS NOT NULL",
      "action_if_failed": "drop",
      "tag": "completeness",
      "description": "Customer name must not be null",
      "priority": "high"
    },
    {
      "rule": "order_date_not_null",
      "rule_type": "row_dq",
      "column_name": "order_date",
      "expectation": "order_date IS NOT NULL",
      "tag": "completeness",
      "description": "Order date must not be null"
    },
    {
      "rule": "product_name_not_null",
      "rule_type": "row_dq",
      "column_name": "product_name",
      "expectation": "product_name IS NOT NULL",
      "tag": "completeness",
      "description": "Product name must not be null"
    },
    {
      "rule": "order_quantity_positive",
      "rule_type": "row_dq",
      "column_name": "order_quantity",
      "expectation": "order_quantity > 0",
      "action_if_failed": "drop",
      "tag": "validity",
      "description": "Order quantity must be greater than zero",
      "priority": "high"
    },
    {
      "rule": "unit_price_positive",
      "rule_type": "row_dq",
      "column_name": "unit_price",
      "expectation": "unit_price > 0",
      "action_if_failed": "drop",
      "tag": "validity",
      "description": "Unit price must be greater than zero",
      "priority": "high"
    },
    {
      "rule": "total_amount_non_negative",
      "rule_type": "row_dq",
      "column_name": "total_amount",
      "expectation": "total_amount >= 0",
      "tag": "validity",
      "description": "Total amount must not be negative"
    },
    {
      "rule": "discount_within_range",
      "rule_type": "row_dq",
      "column_name": "discount",
      "expectation": "discount >= 0 AND discount <= 100",
      "tag": "validity",
      "description": "Discount must be between 0 and 100"
    },
    {
      "rule": "email_format_valid",
      "rule_type": "row_dq",
      "column_name": "customer_email",
      "expectation": "customer_email RLIKE '^[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}$'",
      "tag": "validity",
      "description": "Customer email must match a valid format"
    },
    {
      "rule": "total_matches_qty_times_price",
      "rule_type": "row_dq",
      "column_name": "total_amount",
      "expectation": "abs(total_amount - (order_quantity * unit_price * (1 - discount / 100))) < 0.01",
      "tag": "consistency",
      "description": "Total amount must equal quantity * unit price after discount"
    },
    {
      "rule": "ship_date_after_order_date",
      "rule_type": "row_dq",
      "column_name": "ship_date",
      "expectation": "ship_date IS NULL OR ship_date >= order_date",
      "tag": "consistency",
      "description": "Ship date must not be earlier than order date"
    },
    {
      "rule": "order_status_valid",
      "rule_type": "row_dq",
      "column_name": "order_status",
      "expectation": "order_status IN ('pending', 'shipped', 'delivered', 'cancelled', 'returned')",
      "action_if_failed": "drop",
      "tag": "accuracy",
      "description": "Order status must be one of the allowed values"
    },
    {
      "rule": "country_code_valid",
      "rule_type": "row_dq",
      "column_name": "country_code",
      "expectation": "length(country_code) = 2 AND country_code = upper(country_code)",
      "tag": "accuracy",
      "description": "Country code must be a 2-letter uppercase ISO code"
    },
    {
      "rule": "table_row_count",
      "rule_type": "agg_dq",
      "expectation": "count(*) > 0",
      "action_if_failed": "fail",
      "tag": "completeness",
      "description": "Table must contain at least one row",
      "priority": "high"
    },
    {
      "rule": "customer_id_completeness_ratio",
      "rule_type": "agg_dq",
      "expectation": "count(customer_id) / count(*) > 0.99",
      "action_if_failed": "fail",
      "tag": "completeness",
      "description": "At least 99% of rows must have a customer ID"
    },
    {
      "rule": "order_id_uniqueness",
      "rule_type": "agg_dq",
      "expectation": "count(distinct order_id) = count(order_id)",
      "action_if_failed": "fail",
      "tag": "uniqueness",
      "description": "Order IDs must be unique across all rows"
    },
    {
      "rule": "avg_order_quantity_reasonable",
      "rule_type": "agg_dq",
      "expectation": "avg(order_quantity) BETWEEN 1 AND 1000",
      "tag": "validity",
      "description": "Average order quantity must be within a reasonable range"
    },
    {
      "rule": "max_discount_within_bounds",
      "rule_type": "agg_dq",
      "expectation": "max(discount) <= 100",
      "tag": "validity",
      "description": "No discount should exceed 100%"
    }
  ]
}
